<?xml version="1.0" encoding="UTF-8"?>
<!--
This file contains the assembly bindings required to run EntraCP v30.0

Usage: On each SharePoint server, edit the file:
%systemroot%\Microsoft.NET\Framework64\v4.0.30319\Config\Machine.config
and replace/update the default XML node <runtime /> with the whole XML node <runtime></runtime> below.

The content of this file is different with each version of EntraCP, make sure to use the file corresponding to your version of EntraCP.
-->

<runtime>
<assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
    <dependentAssembly>
        <assemblyIdentity name="System.Threading.Tasks.Extensions" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral"/>
        <bindingRedirect oldVersion="4.2.1.0" newVersion="4.2.4.0"/>
    </dependentAssembly>
    <dependentAssembly>
        <assemblyIdentity name="Azure.Core" publicKeyToken="92742159e12e44c8" culture="neutral"/>
        <bindingRedirect oldVersion="1.50.0.0" newVersion="1.51.1.0"/>
    </dependentAssembly>
    <dependentAssembly>
        <assemblyIdentity name="System.Diagnostics.DiagnosticSource" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral"/>
        <bindingRedirect oldVersion="6.0.0.0-10.0.0.2" newVersion="10.0.0.3"/>
    </dependentAssembly>
    <dependentAssembly>
        <assemblyIdentity name="System.Text.Json" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral"/>
        <bindingRedirect oldVersion="6.0.0.0-10.0.0.0" newVersion="10.0.0.1"/>
    </dependentAssembly>
    <dependentAssembly>
        <assemblyIdentity name="System.Memory" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral"/>
        <bindingRedirect oldVersion="4.0.1.1" newVersion="4.0.5.0"/>
    </dependentAssembly>
    <dependentAssembly>
        <assemblyIdentity name="System.Memory" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral"/>
